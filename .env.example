# Chromecast configuration
CHROMECAST_NAME="Chromecast Audio"

# Flask configuration
FLASK_PORT=3001

# Secret key for Flask session token signing
SECRET_KEY="change_this_to_a_random_secure_string"

# Debug mode
DEBUG=False

# Spotify client ID and secret
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional; must match a redirect URI in Spotify Dashboard
SPOTIFY_REDIRECT_URI=

INCLUDE_SPORT=True

# Optional: systemd unit restarted when you click the URL in the top bar (needs NOPASSWD systemctl for that unit).
# SYSTEMD_SERVICE_NAME=pi-radio-streamer.service
